---
import { getCollection } from "astro:content";
import ToolBadge from "../ui/ToolBadge.astro";
import { formatLevelLabel, formatStageLabel } from "../../data/content-labels";

const lessonEntries = await getCollection("lessons");
const lessonsById = new Map(lessonEntries.map((lesson) => [lesson.id, lesson]));

const paths = [
  {
    id: "regarder-composer",
    label: "Parcours A",
    title: "Regarder et composer",
    description: "Décrire ce qui organise une image avant d’interroger le modèle.",
    lessons: ["voir-composer-generer", "composition-cinematique", "lumiere-couleur", "profondeur-de-champ"],
  },
  {
    id: "stabiliser-intention",
    label: "Parcours B",
    title: "Stabiliser une intention",
    description: "Séparer direction artistique, constantes du personnage et variables autorisées.",
    lessons: ["creation-visuelle", "ambiance-realisme-texture", "character-consistency", "stabiliser"],
  },
  {
    id: "construire-sequence",
    label: "Parcours C",
    title: "Construire une séquence",
    description: "Passer de l’intention au découpage, puis vérifier la fonction de chaque plan.",
    lessons: ["ecriture-scenaristique", "cinematographie", "storyboard-shotlist", "mettre-en-scene"],
  },
  {
    id: "passer-mouvement",
    label: "Parcours D",
    title: "Passer au mouvement",
    description: "Préparer l’animation, les transitions, le montage et la mémoire du pipeline.",
    lessons: ["animer", "image-to-video-transitions", "monter-documenter", "production-ia"],
  },
].map((path) => ({ ...path, entries: path.lessons.map((id) => lessonsById.get(id)).filter(Boolean) }));
---

<section class="learning-hero" aria-labelledby="learning-title">
  <div>
    <span class="eyebrow">Apprendre</span>
    <h1 id="learning-title">Des repères pour regarder, décrire et construire des images.</h1>
    <p>
      Cette partie rassemble les notions utiles avant et pendant la génération : composition, lumière, focale,
      direction artistique, continuité et mise en scène. Chaque fiche propose un point de départ à éprouver,
      pas une méthode définitive.
    </p>
    <div class="hero-actions">
      <a class="button primary" href="#parcours">Voir les parcours</a>
      <a class="button secondary" href="/filmmaking-language/">Consulter le langage cinéma</a>
    </div>
  </div>
  <aside>
    <span class="eyebrow">Mode d’emploi</span>
    <h2>Entrer par la question du moment.</h2>
    <p>Les parcours donnent un ordre de lecture possible. Une fiche peut aussi être ouverte seule depuis un essai ou une étude de cas.</p>
  </aside>
</section>

<div class="container" id="parcours">
  {paths.map((path) => (
    <section class="learning-path-group" id={path.id} aria-labelledby={`${path.id}-title`}>
      <header>
        <span class="eyebrow">{path.label}</span>
        <h2 id={`${path.id}-title`}>{path.title}</h2>
        <p>{path.description}</p>
      </header>
      <div class="learning-path-lessons">
        {path.entries.map((lesson, index) => lesson && (
          <a href={`/formation/${lesson.id}/`} class="learning-lesson-card">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div class="card-meta">
              <b>{formatStageLabel(lesson.data.stage)}</b>
              <b>{formatLevelLabel(lesson.data.level)}</b>
            </div>
            <h3>{lesson.data.title}</h3>
            <p>{lesson.data.description}</p>
            <div class="tool-row">{lesson.data.tools.map((tool) => <ToolBadge tool={tool} />)}</div>
            <strong>Ouvrir la fiche <span aria-hidden="true">→</span></strong>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="learning-bridges" aria-labelledby="bridges-title">
    <div>
      <span class="eyebrow">Poursuivre</span>
      <h2 id="bridges-title">Relier les repères à un essai réel.</h2>
      <p>Les prompts sont conservés avec leur contexte. Les études de cas montrent ensuite ce qui a été fixé, testé ou laissé en suspens.</p>
    </div>
    <nav aria-label="Ressources liées">
      <a href="/experimenter/">Expérimenter <span aria-hidden="true">→</span></a>
      <a href="/projects/lyra-voss/">Étude Lyra Voss <span aria-hidden="true">→</span></a>
      <a href="/resources/">Ressources <span aria-hidden="true">→</span></a>
    </nav>
  </section>
</div>

<style>
  .learning-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.75fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
    border-radius: 24px;
    background: var(--hero-gradient);
    padding: clamp(1.5rem, 4vw, 3rem);
    box-shadow: var(--shadow-lg);
  }

  .learning-hero > div,
  .learning-hero aside {
    display: grid;
    gap: 1rem;
  }

  .learning-hero h1,
  .learning-hero h2,
  .learning-hero p {
    margin: 0;
  }

  .learning-hero h1 {
    max-width: 12em;
  }

  .learning-hero aside {
    border-left: 3px solid var(--accent);
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    padding: 1.4rem;
  }

  .learning-path-group {
    display: grid;
    gap: 1.5rem;
    padding: 4.5rem 0;
    scroll-margin-top: 110px;
  }

  .learning-path-group + .learning-path-group {
    border-top: 1px solid var(--line);
  }

  .learning-path-group > header {
    display: grid;
    max-width: 760px;
    gap: 0.75rem;
  }

  .learning-path-group h2,
  .learning-path-group p {
    margin: 0;
  }

  .learning-path-lessons {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .learning-lesson-card {
    display: grid;
    min-height: 100%;
    gap: 0.8rem;
    border: 1px solid var(--line);
    border-radius: 15px;
    background: var(--surface);
    padding: 1.15rem;
    box-shadow: var(--shadow-sm);
  }

  .learning-lesson-card > span,
  .learning-lesson-card > strong {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .learning-lesson-card h3,
  .learning-lesson-card p {
    margin: 0;
  }

  .learning-lesson-card p {
    font-size: 0.8rem;
  }

  .learning-lesson-card > strong {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-meta b {
    border-radius: var(--radius-pill);
    background: var(--bg-soft);
    color: var(--text-soft);
    padding: 0.28rem 0.5rem;
    font-size: 0.62rem;
  }

  .learning-bridges {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--panel-gradient);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .learning-bridges > div,
  .learning-bridges nav {
    display: grid;
    gap: 0.75rem;
  }

  .learning-bridges h2,
  .learning-bridges p {
    margin: 0;
  }

  .learning-bridges nav a {
    color: var(--accent);
    font-weight: 800;
  }

  @media (max-width: 1100px) {
    .learning-path-lessons {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .learning-hero,
    .learning-bridges {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 560px) {
    .learning-path-lessons {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
