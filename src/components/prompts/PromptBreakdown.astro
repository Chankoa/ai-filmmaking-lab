---
interface Props {
  variables?: string[];
  label?: string;
}

const { variables = [], label = "Variables du prompt" } = Astro.props;
---

{
  variables.length > 0 && (
    <div class="prompt-breakdown-block">
      <strong>{label}</strong>
      <ul class="prompt-breakdown" aria-label={label}>
        {variables.map((variable, index) => (
          <li><span>{String(index + 1).padStart(2, "0")}</span>{variable}</li>
        ))}
      </ul>
    </div>
  )
}
