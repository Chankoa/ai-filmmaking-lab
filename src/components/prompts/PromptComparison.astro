---
import CodeBlock from "../code/CodeBlock.astro";

interface Props {
  before: string;
  after: string;
  title?: string;
  analysis?: string;
}

const {
  before,
  after,
  title = "Du prompt descriptif au prompt de mise en scène",
  analysis,
} = Astro.props;
---

<section class="prompt-comparison" aria-labelledby="prompt-comparison-title">
  <header>
    <span class="lesson-kicker">Comparaison</span>
    <h2 id="prompt-comparison-title">{title}</h2>
    {analysis && <p>{analysis}</p>}
  </header>
  <div class="prompt-comparison__grid">
    <article>
      <span class="prompt-comparison__status prompt-comparison__status--before">Avant</span>
      <p>Le modèle reçoit des mots-clés, mais peu de relations physiques vérifiables.</p>
      <CodeBlock code={before} label="Prompt vague" />
    </article>
    <article>
      <span class="prompt-comparison__status prompt-comparison__status--after">Après</span>
      <p>Les causes visibles, la profondeur et les contraintes deviennent contrôlables.</p>
      <CodeBlock code={after} label="Prompt composé" />
    </article>
  </div>
</section>
