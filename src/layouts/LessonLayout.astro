---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import LessonNav from "../components/course/LessonNav.astro";
import ToolBadge from "../components/ui/ToolBadge.astro";
import { formatStageLabel } from "../data/content-labels";

interface Props {
  lesson: CollectionEntry<"lessons">;
  lessons: CollectionEntry<"lessons">[];
}

const { lesson, lessons } = Astro.props;
const { data } = lesson;
---

<BaseLayout title={`${data.title} - Formation`} description={data.description}>
  <div class="lesson-shell">
    <LessonNav lessons={lessons} currentId={lesson.id} />
    <article class="lesson-article">
      <header class="lesson-header">
        <span class="eyebrow">{formatStageLabel(data.stage)}</span>
        <h1>{data.title}</h1>
        <p>{data.description}</p>
        <div class="tool-row">
          {data.tools.map((tool) => <ToolBadge tool={tool} />)}
        </div>
      </header>
      {data.heroImage && <img class="lesson-visual" src={data.heroImage} alt="" />}
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
