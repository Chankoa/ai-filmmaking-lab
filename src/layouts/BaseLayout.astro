---
import "../styles/global.scss";
import { siteConfig } from "../data/site-config";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = siteConfig.meta.description } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.name}` : siteConfig.name;
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang={siteConfig.lang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta id="meta-theme-color" name="theme-color" content="#f6efe6" />
    <script is:inline>
      (() => {
        const storageKey = "afl-theme";
        try {
          const saved = window.localStorage.getItem(storageKey);
          const theme =
            saved === "dark" || saved === "light"
              ? saved
              : window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {
          document.documentElement.dataset.theme = "light";
          document.documentElement.style.colorScheme = "light";
        }
      })();
    </script>
    <title>{pageTitle}</title>
  </head>
  <body class={currentPath === "/" ? "page-home" : undefined}>
    <a class="skip-link" href="#main-content">Aller au contenu</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href="/" aria-label={siteConfig.name}>
            <span class="brand-mark" aria-hidden="true">AF</span>
            <span class="brand-copy">
              <strong>{siteConfig.name}</strong>
              <small>{siteConfig.baseline}</small>
            </span>
          </a>
          <nav class="main-nav" aria-label="Navigation principale">
            {
              siteConfig.navigation.map((item) => (
                <a class={isActive(item.href) ? "is-active" : ""} href={item.href}>
                  {item.label}
                </a>
              ))
            }
          </nav>
          <div class="site-header__actions">
            <button
              class="theme-switch theme-switch--desktop"
              type="button"
              aria-label="Basculer le mode clair ou sombre"
              aria-pressed="false"
              data-theme-toggle-variant="desktop"
              data-theme-toggle
            >
              <span class="theme-switch__icon theme-switch__icon--sun" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="presentation">
                  <path d="M12 3v2m0 14v2m9-9h-2M5 12H3m14.95 6.95-1.41-1.41M7.46 7.46 6.05 6.05m11.31 0-1.41 1.41M7.46 16.54l-1.41 1.41" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                  <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" fill="none" />
                </svg>
              </span>
              <span class="theme-switch__icon theme-switch__icon--moon is-hidden" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="presentation">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                </svg>
              </span>
              <span class="theme-switch__label">Mode clair</span>
            </button>
            <a class="site-header__cta" href="/formation/">Commencer</a>
            <button
              class="menu-toggle"
              type="button"
              aria-label="Ouvrir le menu"
              aria-expanded="false"
              aria-controls="mobile-menu"
              data-menu-toggle
            >
              <span></span>
              <span></span>
              <span></span>
            </button>
          </div>
        </div>
      </header>
      <div class="mobile-menu" id="mobile-menu" hidden data-mobile-menu>
        <div class="mobile-menu__panel">
          <div class="mobile-menu__top">
            <span class="mobile-menu__eyebrow">Menu</span>
            <button class="mobile-menu__close" type="button" aria-label="Fermer le menu" data-menu-close>
              <svg viewBox="0 0 24 24" role="presentation" aria-hidden="true">
                <path d="M6 6 18 18M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            </button>
          </div>

          <div class="mobile-menu__intro">
            <strong>{siteConfig.name}</strong>
            <p>
              Decouvrir les realisations, consulter les services, comprendre l'approche ou prendre
              contact.
            </p>
          </div>

          <nav class="mobile-menu__nav" aria-label="Navigation mobile">
            {
              siteConfig.navigation.map((item) => (
                <a
                  class={isActive(item.href) ? "is-active" : ""}
                  href={item.href}
                  data-menu-link
                >
                  {item.label}
                </a>
              ))
            }
          </nav>

          <button
            class="theme-switch theme-switch--mobile"
            type="button"
            aria-label="Basculer le mode clair ou sombre"
            aria-pressed="false"
            data-theme-toggle-variant="mobile"
            data-theme-toggle
          >
            <span class="theme-switch__mobile-start">
              <span class="theme-switch__mobile-target" data-theme-target>L</span>
              <span class="theme-switch__mobile-icon">
                <span class="theme-switch__icon theme-switch__icon--sun" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="presentation">
                    <path d="M12 3v2m0 14v2m9-9h-2M5 12H3m14.95 6.95-1.41-1.41M7.46 7.46 6.05 6.05m11.31 0-1.41 1.41M7.46 16.54l-1.41 1.41" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" fill="none" />
                  </svg>
                </span>
                <span class="theme-switch__icon theme-switch__icon--moon is-hidden" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="presentation">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                  </svg>
                </span>
              </span>
            </span>
            <span class="theme-switch__label">Clair</span>
          </button>
        </div>
      </div>
      <main id="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer__inner">
          <p>{siteConfig.name} - Creative production wiki pour cadrer, boarder, prompt et documenter les sequences IA.</p>
          <div class="site-footer__meta" aria-label="Repères de la charte">
            <span>Shots</span>
            <span>Boards</span>
            <span>Prompts</span>
          </div>
        </div>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storageKey = "afl-theme";
        const toggles = Array.from(document.querySelectorAll("[data-theme-toggle]")).filter(
          (element) => element instanceof HTMLButtonElement,
        );
        const menu = document.querySelector("[data-mobile-menu]");
        const menuToggle = document.querySelector("[data-menu-toggle]");
        const menuClose = document.querySelector("[data-menu-close]");
        const menuLinks = document.querySelectorAll("[data-menu-link]");
        const meta = document.getElementById("meta-theme-color");

        const syncToggle = (toggle, theme) => {
          const sun = toggle.querySelector(".theme-switch__icon--sun");
          const moon = toggle.querySelector(".theme-switch__icon--moon");
          const label = toggle.querySelector(".theme-switch__label");
          const target = toggle.querySelector("[data-theme-target]");
          const variant = toggle.dataset.themeToggleVariant;

          toggle.setAttribute("aria-pressed", String(theme === "dark"));
          sun?.classList.toggle("is-hidden", theme === "dark");
          moon?.classList.toggle("is-hidden", theme !== "dark");

          if (label) {
            label.textContent =
              variant === "mobile"
                ? theme === "dark"
                  ? "Sombre"
                  : "Clair"
                : theme === "dark"
                  ? "Mode sombre"
                  : "Mode clair";
          }

          if (target) {
            target.textContent = theme === "dark" ? "L" : "D";
          }
        };
        const media = window.matchMedia ? window.matchMedia("(prefers-color-scheme: dark)") : null;
        const themeColors = {
          light: "#f6efe6",
          dark: "#05080a",
        };

        const applyTheme = (theme, persist = true) => {
          const nextTheme = theme === "dark" ? "dark" : "light";
          root.dataset.theme = nextTheme;
          root.style.colorScheme = nextTheme;
          toggles.forEach((toggle) => syncToggle(toggle, nextTheme));

          if (meta instanceof HTMLMetaElement) {
            meta.content = themeColors[nextTheme];
          }

          if (persist) {
            window.localStorage.setItem(storageKey, nextTheme);
          }
        };

        const saved = window.localStorage.getItem(storageKey);
        const initialTheme =
          saved === "dark" || saved === "light"
            ? saved
            : media?.matches
              ? "dark"
              : "light";

        applyTheme(initialTheme, false);

        toggles.forEach((toggle) => {
          toggle.addEventListener("click", () => {
            applyTheme(root.dataset.theme === "dark" ? "light" : "dark");
          });
        });

        const setMenuOpen = (open) => {
          if (!(menu instanceof HTMLElement) || !(menuToggle instanceof HTMLButtonElement)) return;

          menu.hidden = !open;
          document.body.classList.toggle("menu-open", open);
          menuToggle.setAttribute("aria-expanded", String(open));
        };

        if (menuToggle instanceof HTMLButtonElement) {
          menuToggle.addEventListener("click", () => {
            setMenuOpen(menu instanceof HTMLElement ? menu.hidden : false);
          });
        }

        if (menuClose instanceof HTMLButtonElement) {
          menuClose.addEventListener("click", () => setMenuOpen(false));
        }

        menuLinks.forEach((link) => {
          link.addEventListener("click", () => setMenuOpen(false));
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            setMenuOpen(false);
          }
        });

        window.matchMedia?.("(min-width: 881px)").addEventListener?.("change", (event) => {
          if (event.matches) {
            setMenuOpen(false);
          }
        });

        media?.addEventListener?.("change", (event) => {
          if (!window.localStorage.getItem(storageKey)) {
            applyTheme(event.matches ? "dark" : "light", false);
          }
        });
      })();
    </script>
  </body>
</html>
