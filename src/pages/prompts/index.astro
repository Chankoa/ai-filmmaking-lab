---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import PromptCard from "../../components/prompts/PromptCard.astro";
import { formatPromptCategoryLabel } from "../../data/content-labels";
import { promptCategories } from "../../data/prompt-categories";
import { promptBuilderPipeline } from "../../data/filmmakingLanguage";

const prompts = await getCollection("prompts");
const categories = promptCategories.filter((category) =>
  prompts.some((prompt) => prompt.data.category === category.id)
);
const tags = [...new Set(prompts.flatMap((prompt) => prompt.data.tags))]
  .sort((a, b) => a.localeCompare(b, "fr"));
---

<BaseLayout title="Prompts" description="Bibliothèque de prompts filtrable et réutilisable pour images, personnages et vidéos IA.">
  <CourseHero
    eyebrow="Bibliothèque de prompts"
    title="Prompts comme fiches de production"
    description="Chaque prompt documente une intention, un outil, des variables, des contraintes négatives et un usage pédagogique."
    image="/images/prompts/prompt-library-board.svg"
    imageAlt="Composition visuelle en couches pour construire un prompt"
  />

  <section class="prompt-category-feature" aria-labelledby="language-prompt-bridge-title">
    <div>
      <span class="eyebrow">Base de construction</span>
      <h2 id="language-prompt-bridge-title">Construire le prompt depuis le langage du film.</h2>
      <p>
        La bibliothèque centrale relie émotion, cadrage, focale, composition, mouvement, lumière
        et couleur avant l’écriture du prompt final.
      </p>
      <ol class="prompt-pipeline" aria-label="Pipeline prompt cinema">
        {promptBuilderPipeline.map((step, index) => (
          <li><span>{String(index + 1).padStart(2, "0")}</span>{step}</li>
        ))}
      </ol>
    </div>
    <a class="button primary" href="/filmmaking-language/#ai-prompt-builder">
      Ouvrir le module AI Prompt Builder
    </a>
  </section>

  <section class="prompt-family-index" aria-labelledby="prompt-family-title">
    <div class="section-heading">
      <span class="eyebrow">{categories.length} familles de production</span>
      <h2 id="prompt-family-title">Partir d’une compétence, pas d’une formule magique.</h2>
      <p>Chaque famille relie une intention de mise en scène à un prompt, des contraintes et une leçon.</p>
    </div>
    <div class="prompt-family-grid">
      {
        categories.map((category) => (
          <button type="button" data-prompt-family={category.id}>
            <span>{category.number}</span>
            <strong>{category.title}</strong>
            <small>{category.description}</small>
            <b>{prompts.filter((prompt) => prompt.data.category === category.id).length} fiche(s)</b>
          </button>
        ))
      }
    </div>
  </section>

  <section class="prompt-category-feature" aria-labelledby="composition-prompts-title">
    <div>
      <span class="eyebrow">Nouvelle catégorie · Ambiance et réalisme</span>
      <h2 id="composition-prompts-title">Décrire les causes physiques du réalisme.</h2>
      <p>
        Des fiches relient atmosphère, peau, matières, humidité, profondeur et continuité image-to-video.
      </p>
    </div>
    <a class="button primary" href="/formation/ambiance-realisme-texture/">
      Ouvrir la leçon
    </a>
  </section>

  <section class="tool-panel" aria-labelledby="prompt-list-title">
    <div class="section-heading">
      <span class="eyebrow">Bibliothèque</span>
      <h2 id="prompt-list-title">Prompts de démarrage</h2>
    </div>
    <div class="segmented-control" aria-label="Filtrer les prompts">
      <button type="button" class="is-active" data-prompt-filter="all">Tous</button>
      {categories.map((category) => <button type="button" data-prompt-filter={category.id}>{formatPromptCategoryLabel(category.id)}</button>)}
    </div>
    <div class="prompt-tag-filter" aria-labelledby="prompt-tag-filter-title">
      <div>
        <span class="eyebrow" id="prompt-tag-filter-title">Affiner par tag</span>
        <button type="button" class="is-active" data-prompt-tag="all">Tous les tags</button>
      </div>
      <div class="prompt-tag-filter__list">
        {tags.map((tag) => <button type="button" data-prompt-tag={tag}>{tag}</button>)}
      </div>
    </div>
    <p class="prompt-filter-status" data-prompt-filter-status aria-live="polite"></p>
    <div class="prompt-grid">
      {prompts.map((prompt) => <PromptCard prompt={prompt} />)}
    </div>
  </section>

  <script>
    const promptFilterButtons = document.querySelectorAll("[data-prompt-filter]");
    const promptFamilyButtons = document.querySelectorAll("[data-prompt-family]");
    const promptTagButtons = document.querySelectorAll("[data-prompt-tag]");
    const promptCards = document.querySelectorAll("[data-prompt-card]");
    const promptFilterStatus = document.querySelector("[data-prompt-filter-status]");
    let activeCategory = "all";
    let activeTag = "all";

    const applyPromptFilters = () => {
      promptFilterButtons.forEach((item) => {
        item.classList.toggle("is-active", item.getAttribute("data-prompt-filter") === activeCategory);
      });
      promptTagButtons.forEach((item) => {
        item.classList.toggle("is-active", item.getAttribute("data-prompt-tag") === activeTag);
      });

      let visibleCount = 0;
      promptCards.forEach((card) => {
        const category = card.getAttribute("data-category");
        const tags = JSON.parse(card.getAttribute("data-tags") ?? "[]");
        const categoryMatches = activeCategory === "all" || category === activeCategory;
        const tagMatches = activeTag === "all" || tags.includes(activeTag);
        const isVisible = categoryMatches && tagMatches;
        card.toggleAttribute("hidden", !isVisible);
        if (isVisible) visibleCount += 1;
      });

      if (promptFilterStatus) {
        promptFilterStatus.textContent = `${visibleCount} prompt${visibleCount > 1 ? "s" : ""} affiché${visibleCount > 1 ? "s" : ""}.`;
      }

      const url = new URL(window.location.href);
      activeCategory === "all" ? url.searchParams.delete("category") : url.searchParams.set("category", activeCategory);
      activeTag === "all" ? url.searchParams.delete("tag") : url.searchParams.set("tag", activeTag);
      window.history.replaceState({}, "", url);
    };

    promptFilterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.getAttribute("data-prompt-filter");
        if (filter) {
          activeCategory = filter;
          applyPromptFilters();
        }
      });
    });

    promptTagButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const tag = button.getAttribute("data-prompt-tag");
        if (tag) {
          activeTag = tag;
          applyPromptFilters();
        }
      });
    });

    promptFamilyButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.getAttribute("data-prompt-family");
        if (filter) {
          activeCategory = filter;
          applyPromptFilters();
          document.querySelector("#prompt-list-title")?.scrollIntoView({ behavior: "smooth" });
        }
      });
    });

    const requestedParams = new URLSearchParams(window.location.search);
    const requestedCategory = requestedParams.get("category");
    const requestedTag = requestedParams.get("tag");
    if (
      requestedCategory &&
      [...promptFilterButtons].some(
        (button) => button.getAttribute("data-prompt-filter") === requestedCategory
      )
    ) {
      activeCategory = requestedCategory;
    }
    if (
      requestedTag &&
      [...promptTagButtons].some((button) => button.getAttribute("data-prompt-tag") === requestedTag)
    ) {
      activeTag = requestedTag;
    }
    applyPromptFilters();
  </script>
</BaseLayout>
