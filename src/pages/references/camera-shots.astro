---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import ReferenceBoard from "../../components/references/ReferenceBoard.astro";

const shots = await getCollection("camera-shots");
---

<BaseLayout title="Plans caméra" description="Guide visuel des types de plans, angles et usages narratifs pour prompts IA.">
  <CourseHero
    eyebrow="Plans caméra"
    title="Guide visuel des plans"
    description="Chaque fiche relie une échelle ou un angle à son effet narratif, son mouvement vidéo et un prompt type."
    image="/images/references/reference-atlas-board.svg"
    imageAlt="Grille illustrée des cadrages caméra"
    actions={[
      { label: "Ouvrir la bibliotheque centrale", href: "/filmmaking-language/#shot-sizes", variant: "primary" },
      { label: "Voir les angles", href: "/filmmaking-language/#camera-angles", variant: "secondary" },
    ]}
    stats={[
      { label: "Plans", value: String(shots.length) },
      { label: "Usage", value: "Image + vidéo" },
      { label: "Format", value: "Filtrable" },
    ]}
  />
  <ReferenceBoard shots={shots} />
</BaseLayout>
