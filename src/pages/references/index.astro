---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import MediaCard from "../../components/media/MediaCard.astro";

const shots = await getCollection("camera-shots");
---

<BaseLayout title="Références" description="Boards, guides visuels et références de production pour l'AI filmmaking.">
  <CourseHero
    eyebrow="Références visuelles"
    title="Guides pour voir et cadrer"
    description="Cette section regroupe les références qui aident à nommer un plan, choisir une intention et préparer une génération plus contrôlée."
    image="/assets/visuals/camera-shots.svg"
    imageAlt="Guide visuel des plans caméra"
    stats={[
      { label: "Plans", value: String(shots.length) },
      { label: "Familles", value: "Scale / Angle" },
      { label: "Usage", value: "Prompt-ready" },
    ]}
  />

  <section class="content-grid content-grid--three" aria-label="Boards de référence">
    <MediaCard
      title="Camera Shots"
      description="Types de plans, angles, usages narratifs, mouvements et prompts types."
      image="/assets/visuals/camera-shots.svg"
      href="/references/camera-shots/"
      meta="Guide prioritaire"
    />
    <MediaCard
      title="Moodboards"
      description="Structure future pour univers, palettes, lieux, outfits et références style."
      image="/assets/visuals/production-board.svg"
      href="/resources/"
      meta="À construire"
    />
    <MediaCard
      title="Reference Boards"
      description="Support futur pour personnages, objets, décors et continuity checks."
      image="/assets/visuals/lyra-board.svg"
      href="/projects/lyra-voss/"
      meta="Case study"
    />
  </section>
</BaseLayout>
