---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import MediaCard from "../../components/media/MediaCard.astro";
import { filmmakingLanguageItems } from "../../data/filmmakingLanguage";

const shots = await getCollection("camera-shots");
---

<BaseLayout title="Références" description="Boards, guides visuels et références de production pour l'AI filmmaking.">
  <CourseHero
    eyebrow="Références visuelles"
    title="Guides pour voir et cadrer"
    description="Cette section regroupe les références qui aident à nommer un plan, choisir une intention et préparer une génération plus contrôlée."
    image="/images/references/reference-atlas-board.svg"
    imageAlt="Guide visuel des plans caméra"
    stats={[
      { label: "Plans", value: String(shots.length) },
      { label: "Langage", value: String(filmmakingLanguageItems.length) },
      { label: "Usage", value: "Réutilisable" },
    ]}
  />

  <section class="content-grid content-grid--three" aria-label="Boards de référence">
    <MediaCard
      title="Filmmaking Language"
      description="Bibliotheque centrale : intention, cadrage, composition, angle, focale, mouvement, lumiere, couleur et prompts."
      image="/images/references/reference-atlas-board.svg"
      href="/filmmaking-language/"
      meta="Reference centrale"
    />
    <MediaCard
      title="Plans caméra"
      description="Types de plans, angles, usages narratifs, mouvements et prompts types."
      image="/images/references/reference-atlas-board.svg"
      href="/references/camera-shots/"
      meta="Guide prioritaire"
    />
    <MediaCard
      title="Univers et palettes"
      description="Atmosphères, lieux, matières et densité visuelle pour préparer Vertical Silence et ses variations."
      image="/images/projects/vertical-silence/vertical-silence-atmosphere-board.svg"
      href="/formation/lumiere-couleur/"
      meta="Planifié"
    />
    <MediaCard
      title="Boards personnage"
      description="Planches de référence pour identité, tenue, poses, objets et continuité visuelle."
      image="/images/projects/lyra-voss/face-reference-sheet.svg"
      href="/projects/lyra-voss/"
      meta="Étude de cas"
    />
  </section>
</BaseLayout>
