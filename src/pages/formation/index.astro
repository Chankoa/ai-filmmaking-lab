---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import MediaCard from "../../components/media/MediaCard.astro";
import ToolBadge from "../../components/ui/ToolBadge.astro";

const lessons = (await getCollection("lessons")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Formation" description="Parcours pedagogique progressif pour apprendre l'AI filmmaking par la production.">
  <CourseHero
    eyebrow="Formation"
    title="Parcours de production creative"
    description="Le cursus part de la lecture d'image, passe par le cadrage et la generation, puis aboutit a la stabilisation de personnages, l'image-to-video et la documentation de projets."
    image="/assets/visuals/production-board.svg"
    imageAlt="Board de production avec images, prompts et timeline"
    actions={[
      { label: "Voir les lecons", href: "#lessons", variant: "primary" },
      { label: "Explorer les etudes", href: "/projects/", variant: "secondary" },
    ]}
    stats={[
      { label: "Lecons V1", value: String(lessons.length) },
      { label: "Logique", value: "Image -> Video" },
      { label: "Approche", value: "Tool-aware" },
    ]}
  />

  <section id="lessons" class="section-band">
    <div class="section-heading">
      <span class="eyebrow">Lecons</span>
      <h2>Base extensible</h2>
      <p>Chaque lecon est une entree de collection Astro avec niveau, etape, outils et tags.</p>
    </div>
    <div class="content-grid">
      {
        lessons.map((lesson) => (
          <a class="lesson-card" href={`/formation/${lesson.id}/`}>
            <div class="card-meta">
              <span>{lesson.data.stage}</span>
              <span>{lesson.data.level}</span>
            </div>
            <h3>{lesson.data.title}</h3>
            <p>{lesson.data.description}</p>
            <div class="tool-row">
              {lesson.data.tools.map((tool) => <ToolBadge tool={tool} />)}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="content-grid content-grid--three" aria-label="Pages fortes a construire">
    <MediaCard title="Character Consistency" description="Stabiliser visage, silhouette, tenue et palette." href="/formation/character-consistency/" meta="Priorite" />
    <MediaCard title="Image-to-Video" description="Decrire camera, sujet, environnement et transitions." href="/formation/image-to-video-transitions/" meta="Priorite" />
    <MediaCard title="Lyra Voss" description="Transformer une methode en etude de production complete." href="/projects/lyra-voss/" meta="Case study" />
  </section>
</BaseLayout>
