---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import ReferenceBoard from "../../components/references/ReferenceBoard.astro";

const shots = await getCollection("camera-shots");
---

<BaseLayout title="Plans caméra" description="Alias de la page Plans caméra du wiki de références.">
  <CourseHero
    eyebrow="Plans caméra"
    title="Guide visuel des plans"
    description="Cette route conserve l'ancien chemin et utilise le nouveau board de références."
    image="/images/references/reference-atlas-board.svg"
    imageAlt="Grille illustrée des plans caméra"
    actions={[
      { label: "Ouvrir la bibliothèque centrale", href: "/filmmaking-language/#shot-sizes", variant: "primary" },
      { label: "Voir dans Références", href: "/references/camera-shots/", variant: "secondary" },
    ]}
    stats={[
      { label: "Plans", value: String(shots.length) },
      { label: "Route", value: "Alias" },
      { label: "Format", value: "Filtrable" },
    ]}
  />
  <ReferenceBoard shots={shots} />
</BaseLayout>
