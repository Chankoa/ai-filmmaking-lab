---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillFamilyCard from "../components/course/SkillFamilyCard.astro";
import PathStepCard from "../components/course/PathStepCard.astro";
import ResourceCard from "../components/resources/ResourceCard.astro";
import CinematicImagePlaceholder from "../components/media/CinematicImagePlaceholder.astro";
import { filmmakingProcess } from "../data/filmmaking-process";

const [lessons, prompts, resources, projects, glossary] = await Promise.all([
  getCollection("lessons"),
  getCollection("prompts"),
  getCollection("resources"),
  getCollection("projects"),
  getCollection("glossary"),
]);

const featuredProject = projects.find((project) => project.id === "lyra-voss") ?? projects[0];

const skillFamilies = [
  {
    label: "Création visuelle",
    title: "Voir le monde avant de le styliser",
    description: "Palette, matières, composition et profondeur forment un système stable avant toute génération en série.",
    href: "/formation/creation-visuelle/",
    focus: "Passer d’une intention visuelle à des décisions reproductibles.",
    resourceLabel: "Cheat sheet de composition",
    projectLabel: "Lyra Voss / Vertical Silence",
    variant: "composition" as const,
  },
  {
    label: "Cinématographie",
    title: "Choisir le plan pour son effet dramatique",
    description: "Échelles, angles, mouvements et storyboard servent la lecture de la scène avant l’ornement visuel.",
    href: "/formation/cinematographie/",
    focus: "Transformer une scène en séquence lisible et raccordable.",
    resourceLabel: "Référentiel plans caméra",
    projectLabel: "Storyboard Neon Samurai",
    variant: "urban" as const,
  },
  {
    label: "Production IA",
    title: "Stabiliser, animer, documenter",
    description: "Frames validées, prompts versionnés, clips contrôlés et bible de production deviennent un pipeline au lieu d’essais isolés.",
    href: "/formation/production-ia/",
    focus: "Conserver les décisions utiles d’un plan jusqu’au montage.",
    resourceLabel: "Bible de production",
    projectLabel: "Étude de cas Lyra Voss",
    variant: "portrait" as const,
  },
];

const workflowSteps = filmmakingProcess;
---

<BaseLayout
  title="Accueil"
  description="AI Filmmaking Lab rassemble formation, prompts, références, ressources et études de cas pour produire des séquences audiovisuelles avec l’IA."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero__content">
      <span class="eyebrow">AI Filmmaking Lab</span>
      <h1 id="home-title">Une ressource de production cinématographique pour travailler l’IA sérieusement.</h1>
      <p>
        À mi-chemin entre documentation pédagogique, wiki créatif, bibliothèque de prompts et laboratoire visuel,
        le site relie méthode, cadres, références et études de cas autour de Lyra Voss et de l’univers Vertical Silence.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/formation/">Entrer dans la formation</a>
        <a class="button secondary" href="/projects/lyra-voss/">Voir Lyra Voss</a>
      </div>
      <dl class="home-hero__stats" aria-label="Vue d’ensemble du site">
        <div>
          <dt>{lessons.length}</dt>
          <dd>leçons</dd>
        </div>
        <div>
          <dt>{prompts.length}</dt>
          <dd>prompts</dd>
        </div>
        <div>
          <dt>{resources.length}</dt>
          <dd>ressources</dd>
        </div>
        <div>
          <dt>{glossary.length}</dt>
          <dd>termes</dd>
        </div>
      </dl>
    </div>

    <div class="home-hero__visual">
      <CinematicImagePlaceholder
        src={featuredProject?.data.heroImage}
        alt="Lyra Voss dans Vertical Silence"
        variant="portrait"
        label="Étude de cas active"
        title="Lyra Voss dans Vertical Silence"
        caption="Personnage, bible visuelle, variations de plans et animation contrôlée."
        aspect="5 / 4"
      />
    </div>
  </section>

  <section class="home-band" aria-labelledby="workflow-title">
    <div class="section-heading">
      <span class="eyebrow">Parcours</span>
      <h2 id="workflow-title">Un workflow lisible de la lecture du cadre jusqu’à la documentation.</h2>
      <p>Les verbes du site suivent la chaîne réelle de travail : voir, composer, créer l'ambiance, générer, stabiliser, mettre en scène, animer, monter, documenter.</p>
    </div>
    <div class="workflow-grid">
      {workflowSteps.map((step) => <PathStepCard {...step} />)}
    </div>
  </section>

  <section class="home-band" aria-labelledby="families-title">
    <div class="section-heading">
      <span class="eyebrow">Familles de compétences</span>
      <h2 id="families-title">Trois portes d’entrée, un même standard de production.</h2>
      <p>Chaque famille relie une leçon d’entrée, des ressources de support et un projet qui montre l’usage concret.</p>
    </div>
    <div class="skill-grid">
      {skillFamilies.map((family) => <SkillFamilyCard {...family} />)}
    </div>
  </section>

  <section class="home-band home-band--library" aria-labelledby="library-title">
    <div class="section-heading section-heading--center">
      <span class="eyebrow">Bibliothèque</span>
      <h2 id="library-title">Prompts, références, glossaire et ressources documentées.</h2>
      <p>Chaque bibliothèque sert une tâche précise au lieu de répéter les mêmes contenus sous plusieurs noms.</p>
    </div>

    <div class="home-shelf-grid">
      <ResourceCard
        eyebrow="Prompts"
        title="Bibliothèque de prompts"
        description="Des fiches reliées à une intention, un outil, une leçon et des contraintes négatives observables."
        href="/prompts/"
        status="Prêt"
        meta={`${prompts.length} fiches`}
        variant="composition"
        badges={["Composition", "Storyboard", "Animer"]}
        actionLabel="Ouvrir les prompts"
      />
      <ResourceCard
        eyebrow="Références"
        title="Voir avant de générer"
        description="Plans caméra, boards visuels et repères de cadrage pour choisir un cadre au lieu d’improviser."
        href="/references/"
        status="Prêt"
        meta="Guides visuels"
        variant="urban"
        badges={["Plans caméra", "Angles", "Usage narratif"]}
        actionLabel="Ouvrir les références"
      />
      <ResourceCard
        eyebrow="Ressources"
        title="Templates de production"
        description="Checklist shot-list, bible de production et cheat sheets pour conserver ce qui doit rester stable."
        href="/resources/"
        status="Prêt"
        meta={`${resources.length} ressources`}
        variant="storyboard"
        badges={["Checklist", "Template", "Cheat sheet"]}
        actionLabel="Ouvrir les ressources"
      />
      <ResourceCard
        eyebrow="Glossaire"
        title="Vocabulaire de production"
        description="Un référentiel pour aligner cadrage, lumière, prompts et workflow sans flottement de termes."
        href="/glossary/"
        status="Prêt"
        meta={`${glossary.length} termes`}
        variant="depth"
        badges={["Cinéma", "Vidéo", "Prompt"]}
        actionLabel="Ouvrir le glossaire"
      />
    </div>
  </section>

  <section class="home-case-study" aria-labelledby="case-study-title">
    <div class="home-case-study__copy">
      <span class="eyebrow">Étude de cas centrale</span>
      <h2 id="case-study-title">Lyra Voss sert de fil rouge pour éprouver méthode, cohérence et documentation.</h2>
      <p>
        Le site ne présente pas seulement des prompts isolés. Il montre comment une bible visuelle,
        des boards, des frames approuvées et des clips contrôlés se répondent dans un même univers.
      </p>
      <div class="home-case-study__actions">
        <a class="button primary" href="/projects/lyra-voss/">Ouvrir le projet</a>
        <a class="button secondary" href="/resources/composition-cheat-sheet/">Ouvrir le guide de composition</a>
      </div>
    </div>

    <div class="home-case-study__note">
      <strong>Vertical Silence</strong>
      <p>Univers en cours de consolidation comme surface autonome. Pour ce sprint, il structure surtout les leçons, prompts et cas Lyra Voss.</p>
    </div>
  </section>

  <style>
    .home-hero,
    .home-case-study {
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(360px, 0.82fr);
      gap: 2rem;
      align-items: center;
    }

    .home-hero {
      position: relative;
      overflow: hidden;
      border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
      border-radius: 24px;
      background:
        radial-gradient(circle at 14% 18%, color-mix(in srgb, var(--neon-magenta) 18%, transparent), transparent 29%),
        radial-gradient(circle at 82% 24%, color-mix(in srgb, var(--neon-cyan) 18%, transparent), transparent 27%),
        linear-gradient(145deg, color-mix(in srgb, var(--surface) 92%, #09111d 8%), color-mix(in srgb, var(--surface-muted) 90%, #05080f 10%));
      padding: clamp(1.5rem, 4vw, 3rem);
      box-shadow: var(--shadow-lg);
    }

    .home-hero__content,
    .home-hero__visual,
    .home-case-study__copy {
      display: grid;
      min-width: 0;
      gap: 1rem;
    }

    .home-hero__content h1,
    .home-case-study__copy h2 {
      margin: 0;
    }

    .home-hero__content h1 {
      max-width: 10.5em;
      font-size: clamp(3.15rem, 5vw, 4.5rem);
      overflow-wrap: break-word;
    }

    .home-hero__content > p {
      max-width: 62ch;
    }

    .home-hero__stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.75rem;
      margin: 0;
    }

    .home-hero__stats div {
      border: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
      border-radius: 14px;
      background: color-mix(in srgb, var(--surface) 88%, transparent);
      padding: 0.9rem 0.95rem;
    }

    .home-hero__stats dt {
      color: var(--text);
      font-family: "Manrope", "Segoe UI", sans-serif;
      font-size: 1.35rem;
      font-weight: 800;
      line-height: 1;
    }

    .home-hero__stats dd {
      margin: 0.45rem 0 0;
      color: var(--text-soft);
      font-size: 0.75rem;
    }

    .home-band {
      padding: 5.25rem 0;
    }

    .workflow-grid,
    .skill-grid,
    .home-shelf-grid {
      display: grid;
      gap: 1rem;
    }

    .workflow-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .skill-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .home-shelf-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .home-band--library {
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .home-case-study {
      gap: 1rem;
      border: 1px solid var(--line);
      border-radius: 22px;
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, transparent), color-mix(in srgb, var(--surface-muted) 84%, transparent));
      padding: clamp(1.5rem, 3vw, 2.5rem);
      box-shadow: var(--shadow-sm);
    }

    .home-case-study__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .home-case-study__note {
      display: grid;
      gap: 0.65rem;
      align-content: start;
      border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
      border-radius: 18px;
      background: color-mix(in srgb, var(--surface-muted) 88%, transparent);
      padding: 1rem;
    }

    .home-case-study__note strong,
    .home-case-study__note p {
      margin: 0;
    }

    @media (max-width: 1100px) {
      .workflow-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 1060px) {
      .home-hero,
      .home-case-study,
      .skill-grid,
      .home-shelf-grid {
        grid-template-columns: minmax(0, 1fr);
      }

      .workflow-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .home-hero__stats,
      .workflow-grid {
        grid-template-columns: minmax(0, 1fr);
      }
    }
  </style>
</BaseLayout>
