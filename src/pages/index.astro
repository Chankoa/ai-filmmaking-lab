---
import BaseLayout from "../layouts/BaseLayout.astro";
import PathStepCard from "../components/course/PathStepCard.astro";
import ReferenceImage from "../components/lab/ReferenceImage.astro";
import ResearchStatus from "../components/lab/ResearchStatus.astro";
import { filmmakingProcess } from "../data/filmmaking-process";

const labEntrances = [
  {
    title: "Apprendre",
    description: "Acquérir les notions de cadre, de lumière, de mise en scène et de continuité nécessaires pour formuler une intention visuelle.",
    href: "/formation/",
    action: "Consulter les repères",
  },
  {
    title: "Expérimenter",
    description: "Tester des prompts, comparer des variantes et observer ce que les modèles conservent, transforment ou perdent.",
    href: "/experimenter/",
    action: "Voir les protocoles",
  },
  {
    title: "Produire",
    description: "Organiser les essais en plans, en séquences et en documents de production réutilisables.",
    href: "/produire/",
    action: "Parcourir le workflow",
  },
  {
    title: "Documenter",
    description: "Conserver les références, les choix, les échecs et les corrections afin que chaque test puisse nourrir le suivant.",
    href: "/projects/",
    action: "Lire les études de cas",
  },
];
---

<BaseLayout
  title="Accueil"
  description="AI Filmmaking Lab rassemble des notes, des méthodes, des essais visuels et des études de cas sur la création cinématographique assistée par IA."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero__content">
      <span class="eyebrow">AI Filmmaking Lab</span>
      <h1 id="home-title">Apprendre le cinéma. Expérimenter avec l’IA. Documenter ce qui résiste.</h1>
      <p>
        Ce site rassemble des notes, des méthodes, des essais visuels et des études de cas autour de la création
        cinématographique assistée par IA. Il ne propose pas une recette définitive : il conserve les questions,
        les résultats et les outils qui permettent de poursuivre la recherche.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="#entrees">Explorer le laboratoire</a>
        <a class="button secondary" href="/projects/lyra-voss/">Voir l’étude de cas Lyra Voss</a>
      </div>
    </div>

    <ReferenceImage
      src="/images/lyra-voss/references/lyra-reference-body.webp"
      alt="Vue en pied de Lyra Voss dans un corridor humide"
      width={768}
      height={1376}
      caption="Lyra Voss — personnage-test du laboratoire"
      status="Référence canonique"
      eager={true}
      objectPosition="center 24%"
    />
  </section>

  <section id="entrees" class="home-band" aria-labelledby="entrances-title">
    <div class="section-heading">
      <span class="eyebrow">Quatre manières d’entrer dans le Lab</span>
      <h2 id="entrances-title">Choisir l’action utile au travail en cours.</h2>
      <p>Ces quatre entrées organisent les contenus sans imposer un parcours unique.</p>
    </div>
    <div class="lab-entry-grid">
      {labEntrances.map((entry, index) => (
        <a class="lab-entry-card" href={entry.href}>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{entry.title}</h3>
          <p>{entry.description}</p>
          <strong>{entry.action} <span aria-hidden="true">→</span></strong>
        </a>
      ))}
    </div>
  </section>

  <section class="home-research" aria-labelledby="research-title">
    <div class="home-research__copy">
      <div class="home-research__status">
        <ResearchStatus status="Recherche active" />
        <ResearchStatus status="Documentation en cours" />
      </div>
      <span class="eyebrow">Recherche en cours</span>
      <h2 id="research-title">Lyra Voss, un personnage-test pour observer la continuité.</h2>
      <p>
        Lyra Voss est utilisée pour étudier la cohérence d’identité, la variation des cadrages, la continuité des
        matières et le passage de l’image fixe au plan animé. Les références sont identifiées ; les résultats de
        génération restent à qualifier protocole par protocole.
      </p>
      <a class="button primary" href="/projects/lyra-voss/">Ouvrir le journal d’étude</a>
    </div>
    <div class="home-research__question">
      <span>Question de recherche</span>
      <p>Que reste-t-il de l’identité lorsque changent le cadre, la focale, la posture, la lumière et l’outil ?</p>
    </div>
  </section>

  <section class="home-band" aria-labelledby="workflow-title">
    <div class="section-heading">
      <span class="eyebrow">Du premier regard au retour d’expérience</span>
      <h2 id="workflow-title">Un chemin possible, à adapter au projet et à l’outil.</h2>
      <p>Observer → Composer → Générer → Stabiliser → Mettre en scène → Animer → Monter → Documenter.</p>
    </div>
    <div class="workflow-grid">
      {filmmakingProcess.map((step) => <PathStepCard {...step} />)}
    </div>
  </section>

  <section class="home-intent" aria-labelledby="intent-title">
    <span class="eyebrow">Note d’intention</span>
    <h2 id="intent-title">Des documents de travail plutôt que des vérités définitives.</h2>
    <p>
      Le Lab est construit depuis la pratique. Les outils évoluent vite, les résultats restent instables et certaines
      méthodes vieillissent. Les contenus sont donc considérés comme des documents de travail versionnés plutôt que
      comme des vérités définitives.
    </p>
    <a class="text-link" href="/a-propos/">À propos du Lab <span aria-hidden="true">→</span></a>
  </section>

  <style>
    .home-hero,
    .home-research {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
      gap: clamp(1.25rem, 4vw, 3rem);
      align-items: center;
    }

    .home-hero {
      position: relative;
      overflow: hidden;
      border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
      border-radius: 24px;
      background: var(--hero-gradient);
      padding: clamp(1.5rem, 4vw, 3rem);
      box-shadow: var(--shadow-lg);
    }

    .home-hero__content,
    .home-research__copy {
      display: grid;
      min-width: 0;
      gap: 1rem;
    }

    .home-hero h1 {
      max-width: 12em;
      margin: 0;
      font-size: clamp(3rem, 5vw, 4.5rem);
      overflow-wrap: anywhere;
    }

    .home-hero p,
    .home-research p,
    .home-intent p {
      margin: 0;
    }

    .home-hero :global(.reference-image__media) {
      max-height: 560px;
    }

    .home-band {
      padding: 5.25rem 0;
    }

    .lab-entry-grid,
    .workflow-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }

    .lab-entry-card {
      display: grid;
      min-height: 100%;
      gap: 0.85rem;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--surface);
      padding: 1.25rem;
      box-shadow: var(--shadow-sm);
    }

    .lab-entry-card > span,
    .lab-entry-card > strong {
      color: var(--accent);
      font-size: 0.76rem;
      font-weight: 800;
    }

    .lab-entry-card h3,
    .lab-entry-card p {
      margin: 0;
    }

    .lab-entry-card strong {
      margin-top: auto;
      padding-top: 0.5rem;
    }

    .home-research,
    .home-intent {
      border: 1px solid var(--line);
      border-radius: 22px;
      background: var(--panel-gradient);
      padding: clamp(1.5rem, 4vw, 3rem);
      box-shadow: var(--shadow-sm);
    }

    .home-research__status {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .home-research__question {
      display: grid;
      gap: 0.75rem;
      border-left: 3px solid var(--accent);
      background: color-mix(in srgb, var(--surface) 86%, transparent);
      padding: 1.25rem;
    }

    .home-research__question span {
      color: var(--accent);
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .home-research__question p {
      color: var(--text);
      font-family: "Manrope", "Segoe UI", sans-serif;
      font-size: clamp(1.25rem, 2vw, 1.65rem);
      font-weight: 700;
      line-height: 1.35;
    }

    .home-intent {
      display: grid;
      max-width: 920px;
      gap: 1rem;
      margin: 0 auto;
    }

    .home-intent h2 {
      margin: 0;
    }

    @media (max-width: 1100px) {
      .lab-entry-grid,
      .workflow-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 820px) {
      .home-hero,
      .home-research {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    @media (max-width: 600px) {
      .lab-entry-grid,
      .workflow-grid {
        grid-template-columns: minmax(0, 1fr);
      }
    }
  </style>
</BaseLayout>
