---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolBadge from "../components/ui/ToolBadge.astro";
import { formatLevelLabel, formatStageLabel, formatStatusLabel } from "../data/content-labels";

const [lessonEntries, prompts, projects, shots, resources] = await Promise.all([
  getCollection("lessons"),
  getCollection("prompts"),
  getCollection("projects"),
  getCollection("camera-shots"),
  getCollection("resources"),
]);

const lessons = lessonEntries.sort((a, b) => a.data.order - b.data.order);
const featuredLesson = lessons[0];

const domains = [
  {
    label: "Création visuelle",
    title: "Images et direction artistique",
    description: "Composition, lumière, style, références et prompts reproductibles.",
    href: "/prompts/",
    icon: "✦",
  },
  {
    label: "Cinématographie",
    title: "Plans et mouvements caméra",
    description: "Cadres, angles, focales et intentions narratives pour chaque séquence.",
    href: "/references/camera-shots/",
    icon: "◫",
  },
  {
    label: "Production IA",
    title: "Personnages et vidéo",
    description: "Continuité visuelle, image-to-video, transitions et montage.",
    href: "/projects/",
    icon: "◇",
  },
];

const highlights = [
  {
    value: String(lessons.length),
    label: "leçons structurées",
    description: "Un parcours court, progressif et directement applicable.",
  },
  {
    value: String(prompts.length + resources.length),
    label: "ressources pratiques",
    description: "Prompts, checklists et supports à réutiliser en production.",
  },
  {
    value: String(shots.length),
    label: "références caméra",
    description: "Un vocabulaire visuel pour cadrer chaque intention.",
  },
];
---

<BaseLayout
  title="Hub de formation"
  description="Le hub de formation AI Filmmaking Lab pour apprendre à concevoir, générer et produire des séquences audiovisuelles avec l’IA."
>
  <section class="hub-hero" aria-labelledby="hub-title">
    <div class="hub-hero__content">
      <span class="eyebrow">Hub de formation</span>
      <h1 id="hub-title">Passez de l’idée à une séquence maîtrisée.</h1>
      <p>
        Explorez un parcours progressif pour composer vos images, stabiliser vos personnages,
        préparer vos plans vidéo et documenter une production audiovisuelle assistée par l’IA.
      </p>

      <dl class="hub-metrics" aria-label="Contenu disponible">
        <div>
          <dt>{lessons.length}</dt>
          <dd>leçons</dd>
        </div>
        <div>
          <dt>{prompts.length}</dt>
          <dd>prompts</dd>
        </div>
        <div>
          <dt>{projects.length}</dt>
          <dd>projets</dd>
        </div>
      </dl>

      <div class="hero-actions">
        <a class="button primary" href="#parcours">Explorer la formation</a>
        <a class="button secondary" href="#domaines">Voir les domaines</a>
      </div>
    </div>

    <aside class="hub-feature" aria-label="Parcours recommandé">
      <div class="hub-feature__top">
        <span>Parcours recommandé</span>
        <span>01</span>
      </div>
      <div>
        <span class="card-kicker">Commencez ici</span>
        <h2>{featuredLesson.data.title}</h2>
        <p>{featuredLesson.data.description}</p>
      </div>
      <div class="hub-feature__visual" aria-hidden="true">
        <img src={featuredLesson.data.heroImage} alt="" />
      </div>
      <div class="hub-feature__meta">
        <span>{featuredLesson.data.estimatedTime}</span>
        <span>{formatLevelLabel(featuredLesson.data.level)}</span>
        <span>{formatStageLabel(featuredLesson.data.stage)}</span>
      </div>
      <a class="button primary" href={`/formation/${featuredLesson.id}/`}>
        Démarrer la première leçon
      </a>
    </aside>
  </section>

  <section class="hub-section" aria-labelledby="approach-title">
    <div class="hub-section__intro">
      <div>
        <span class="eyebrow">Une méthode concrète</span>
        <h2 id="approach-title">Des repères clairs pour produire, pas seulement expérimenter.</h2>
      </div>
      <p>
        Chaque contenu relie une intention créative, une méthode de travail et un livrable.
        Vous pouvez suivre le parcours dans l’ordre ou ouvrir directement le sujet utile à votre projet.
      </p>
    </div>

    <div class="highlight-grid">
      {
        highlights.map((item) => (
          <article class="highlight-card">
            <strong>{item.value}</strong>
            <h3>{item.label}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="hub-section" id="domaines" aria-labelledby="domains-title">
    <div class="section-heading section-heading--center">
      <span class="eyebrow">Domaines</span>
      <h2 id="domains-title">Explorez les familles de compétences.</h2>
      <p>Choisissez une porte d’entrée selon votre besoin du moment.</p>
    </div>

    <div class="domain-grid">
      {
        domains.map((domain) => (
          <a class="domain-card" href={domain.href}>
            <span class="domain-card__icon" aria-hidden="true">{domain.icon}</span>
            <span class="card-kicker">{domain.label}</span>
            <h3>{domain.title}</h3>
            <p>{domain.description}</p>
            <span class="text-link">Explorer <span aria-hidden="true">→</span></span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="hub-section" id="parcours" aria-labelledby="lessons-title">
    <div class="hub-section__intro hub-section__intro--aligned">
      <div>
        <span class="eyebrow">Catalogue</span>
        <h2 id="lessons-title">Le parcours de formation.</h2>
      </div>
      <p>{lessons.length} leçons disponibles, de l’analyse visuelle à la mise en mouvement.</p>
    </div>

    <div class="lesson-catalogue">
      {
        lessons.map((lesson, index) => (
          <a class="catalogue-card" href={`/formation/${lesson.id}/`}>
            <div class="catalogue-card__number">{String(index + 1).padStart(2, "0")}</div>
            <div class="catalogue-card__content">
              <div class="card-meta">
                <span>{formatStageLabel(lesson.data.stage)}</span>
                <span>{formatLevelLabel(lesson.data.level)}</span>
              </div>
              <h3>{lesson.data.title}</h3>
              <p>{lesson.data.description}</p>
              <div class="tool-row">
                {lesson.data.tools.map((tool) => <ToolBadge tool={tool} />)}
              </div>
            </div>
            <div class="catalogue-card__aside">
              <span>{lesson.data.estimatedTime ?? "À votre rythme"}</span>
              <span class="catalogue-card__arrow" aria-hidden="true">→</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="hub-section hub-section--split" aria-labelledby="resources-title">
    <div class="hub-panel hub-panel--violet">
      <span class="eyebrow">Bibliothèque</span>
      <h2 id="resources-title">Des outils prêts pour vos productions.</h2>
      <p>
        Retrouvez les prompts, références caméra et ressources qui accompagnent chaque étape.
      </p>
      <div class="hub-panel__links">
        <a href="/prompts/">
          <strong>{prompts.length} prompts</strong>
          <span>Image, vidéo, personnage et transition</span>
        </a>
        <a href="/references/">
          <strong>{shots.length} références</strong>
          <span>Plans, angles et usages narratifs</span>
        </a>
        <a href="/resources/">
          <strong>{resources.length} ressources</strong>
          <span>Templates et checklists de production</span>
        </a>
      </div>
    </div>

    <div class="hub-panel">
      <span class="eyebrow">Études de cas</span>
      <h2>Apprenez à partir de projets documentés.</h2>
      <p>Chaque projet rassemble brief, références, prompts, pipeline et analyse critique.</p>
      <div class="project-preview-grid">
        {
          projects.slice(0, 2).map((project) => (
            <a class="project-preview" href={`/projects/${project.id}/`}>
              {project.data.heroImage && <img src={project.data.heroImage} alt="" loading="lazy" />}
              <div>
                <span class="card-kicker">{formatStatusLabel(project.data.status)}</span>
                <h3>{project.data.title}</h3>
                <span class="text-link">Voir le projet →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="hub-cta" aria-labelledby="cta-title">
    <span class="eyebrow">Votre prochain plan commence ici</span>
    <h2 id="cta-title">Construisez une méthode créative que vous pourrez répéter.</h2>
    <p>Commencez par observer, composer et générer, puis développez votre propre pipeline.</p>
    <div class="hero-actions">
      <a class="button primary" href={`/formation/${featuredLesson.id}/`}>Commencer maintenant</a>
      <a class="button secondary" href="/projects/">Explorer les projets</a>
    </div>
  </section>
</BaseLayout>
