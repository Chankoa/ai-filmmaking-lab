---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Projets" description="Ancienne route des projets, conservée comme alias.">
  <section class="section-band">
    <div class="section-heading">
      <span class="eyebrow">Alias</span>
      <h1>Les projets sont maintenant dans Projects</h1>
      <p>La nouvelle route principale utilise `/projects` pour rester alignée avec l'architecture de collection.</p>
      <div class="hero-actions">
        <a class="button primary" href="/projects/">Ouvrir /projects</a>
      </div>
    </div>
  </section>
</BaseLayout>
