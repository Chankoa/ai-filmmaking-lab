---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import MediaCard from "../../components/media/MediaCard.astro";
import { formatStatusLabel } from "../../data/content-labels";

const projects = await getCollection("projects");
---

<BaseLayout title="Projects" description="Études de cas de production IA : personnages, univers, prompts, vidéos et documentation.">
  <CourseHero
    eyebrow="Case Studies"
    title="Projets documentés"
    description="Les projets transforment les exercices en études de production : brief, références, prompt maître, frames, animation, montage et critique."
    image="/assets/visuals/production-board.svg"
    imageAlt="Board de production créative"
    stats={[
      { label: "Projets", value: String(projects.length) },
      { label: "Statut", value: "V1" },
      { label: "Sortie", value: "Production bible" },
    ]}
  />

  <section class="content-grid" aria-label="Études de cas">
    {
      projects.map((project) => (
        <MediaCard
          title={project.data.title}
          description={project.data.description}
          image={project.data.heroImage}
          href={`/projects/${project.id}/`}
          meta={formatStatusLabel(project.data.status)}
        />
      ))
    }
  </section>
</BaseLayout>
