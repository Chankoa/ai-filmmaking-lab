---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import ResourceCard from "../../components/resources/ResourceCard.astro";
import { formatResourceTypeLabel, formatStatusLabel } from "../../data/content-labels";

const resources = await getCollection("resources");

const resourceVariantByType: Record<string, "urban" | "board" | "portrait" | "storyboard" | "depth" | "light" | "composition"> = {
  guide: "composition",
  template: "board",
  checklist: "storyboard",
  reference: "depth",
  external: "urban",
};
---

<BaseLayout title="Ressources" description="Templates, checklists et ressources pour documenter les productions AI filmmaking.">
  <CourseHero
    eyebrow="Ressources"
    title="Guides, templates et checklists"
    description="Des supports réutilisables pour cadrer la composition, documenter une production et contrôler chaque plan avant génération."
    image="/images/resources/resource-pipeline-board.svg"
    imageAlt="Pipeline de ressources de production"
    stats={[
      { label: "Ressources", value: String(resources.length) },
      { label: "Format", value: "Évolutif" },
      { label: "Usage", value: "Documentation" },
    ]}
  />

  <section class="resource-feature" aria-labelledby="composition-resource-title">
    <div>
      <span class="eyebrow">Nouvelle référence</span>
      <h2 id="composition-resource-title">Composition cinématique · Cheat sheet</h2>
      <p>
        18 structures de cadre, leurs effets narratifs et des patterns de prompt orientés AI filmmaking.
      </p>
    </div>
    <a class="button primary" href="/resources/composition-cheat-sheet/">Ouvrir le guide</a>
  </section>

  <section class="content-grid" aria-label="Ressources">
    {
      resources.map((resource) => (
        <ResourceCard
          eyebrow={formatResourceTypeLabel(resource.data.type)}
          title={resource.data.title}
          description={resource.data.description}
          href={resource.data.href}
          status={formatStatusLabel(resource.data.status)}
          badges={resource.data.tools}
          variant={resourceVariantByType[resource.data.type] ?? "board"}
        />
      ))
    }
  </section>
</BaseLayout>
