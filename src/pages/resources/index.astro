---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CourseHero from "../../components/course/CourseHero.astro";
import ToolBadge from "../../components/ui/ToolBadge.astro";
import { formatResourceTypeLabel, formatStatusLabel } from "../../data/content-labels";

const resources = await getCollection("resources");
---

<BaseLayout title="Resources" description="Templates, checklists et ressources pour documenter les productions AI filmmaking.">
  <CourseHero
    eyebrow="Resources"
    title="Templates et checklists"
    description="La section ressources préparera les supports réutilisables : production bible, shot-list, prompt packs, grilles d'analyse et workflows."
    image="/assets/visuals/pipeline-board.svg"
    imageAlt="Pipeline de ressources de production"
    stats={[
      { label: "Ressources", value: String(resources.length) },
      { label: "Format", value: "Évolutif" },
      { label: "Usage", value: "Documentation" },
    ]}
  />

  <section class="content-grid" aria-label="Ressources">
    {
      resources.map((resource) => (
        <article class="resource-card">
          <div class="card-meta">
            <span>{formatResourceTypeLabel(resource.data.type)}</span>
            <span>{formatStatusLabel(resource.data.status)}</span>
          </div>
          <h3>{resource.data.title}</h3>
          <p>{resource.data.description}</p>
          <div class="tool-row">
            {resource.data.tools.map((tool) => <ToolBadge tool={tool} />)}
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
