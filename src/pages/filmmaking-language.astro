---
import BaseLayout from "../layouts/BaseLayout.astro";
import CourseHero from "../components/course/CourseHero.astro";
import FilmmakingLanguageBoard from "../components/filmmaking-language/FilmmakingLanguageBoard.astro";
---

<BaseLayout
  title="Langage cinématographique"
  description="Bibliothèque de repères cinématographiques pour décrire l’intention, le cadre, la lumière et le mouvement."
>
  <div class="language-page">
    <CourseHero
      eyebrow="Apprendre · Langage cinématographique"
      title="Décrire un plan avant de le traduire en prompt."
      description="Des repères pour relier intention narrative, cadrage, composition, angle, focale, mouvement, lumière, couleur et construction de prompt."
      image="/images/references/reference-atlas-board.svg"
      imageAlt="Atlas visuel des decisions de mise en scene"
      actions={[
        { label: "Explorer les fiches", href: "#language-reference-title", variant: "primary" },
        { label: "Construire un prompt", href: "#ai-prompt-builder", variant: "secondary" },
      ]}
    />

    <FilmmakingLanguageBoard />
  </div>
</BaseLayout>
